import "io.mini";

// functions begin with the fun keyword
fun greet() {
    print("Hello, World!")
}

// calling the greet function
greet()

// Functions can have parameters and return types
fun add(a: int, b: int): int {
    return a + b
}

let result = add(5, 10)
print(result)

fun multiply(a: float, b: float): float {
    return a * b
}

let product = multiply(2.5, 4.0)
print(product)
