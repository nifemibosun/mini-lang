func is_any_greater(a: int32, b: int32): bool {
	if (a > b) {
		println("A is greater than B");
		return true;
	} else if (b > a) {
		println("B is greater than A");
		return true;
	} else {
		println("A = B <=> B = A"); // This mean that A = B implies B = A
		return false;
	}

	println("Check completed.);
}