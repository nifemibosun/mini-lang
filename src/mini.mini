// MiniLang Interpreter written in MiniLang

// Data structure to hold variables
fun initialize_memory() -> Object {
    return {};
}

// Parse a line of code and return the action
fun parse_line(line: string) -> Object {
    if line.starts_with("let ") {
        return {"type": "variable", "action": "declare", "line": line};
    } else if line.starts_with("const ") {
        return {"type": "variable", "action": "declare_const", "line": line};
    } else if line.starts_with("print(") {
        return {"type": "io", "action": "print", "line": line};
    } else if line.ends_with("()") {
        return {"type": "function_call", "action": "call", "line": line};
    } else {
        return {"type": "unknown", "line": line};
    }
}

// Execute a single parsed action
fun execute_action(action: Object, memory: Object) -> nil {
    if action["type"] == "variable" {
        if action["action"] == "declare" {
            let parts: Array = action["line"].split("=");
            let var_name: string = parts[0].trim().replace("let ", "");
            let value: string = parts[1].trim().replace(";", "");
            memory[var_name] = value;
        } else if action["action"] == "declare_const" {
            let parts: Array = action["line"].split("=");
            let const_name: string = parts[0].trim().replace("const ", "");
            let value: string = parts[1].trim().replace(";", "");
            memory[const_name] = value; // Assume immutability is enforced later
        }
    } else if action["type"] == "io" && action["action"] == "print" {
        let content: string = action["line"]
            .replace("print(", "")
            .replace(");", "")
            .trim();
        if memory.has_key(content) {
            print(memory[content]);
        } else {
            print(content.replace("\"", ""));
        }
    }
}

// Main interpreter loop
fun run_code(code: string) -> nil {
    let memory: Object = initialize_memory();
    let lines: Array = code.split("\n");
    for line in lines {
        if line.trim().starts_with("//") || line.trim().length == 0 {
            continue;
        }
        let action: Object = parse_line(line.trim());
        execute_action(action, memory);
    }
}

// Main entry point
fun main() -> nil {
    let code: string = read_file("example.mini");
    run_code(code);
}
